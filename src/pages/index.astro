---
import "../styles/app.css";
import "../styles/document.css";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Offerten & Rechnungen</title>
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='%23111'/%3E%3Ctext x='8' y='12' text-anchor='middle' font-family='monospace' font-size='11' fill='%23fff'%3EB%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <div class="app">
      <aside class="editor">
        <div class="editor-inner">
          <header class="editor-header">
            <h1>BILLS</h1>
            <div class="document-bar">
              <select id="document-select" title="Dokument wählen"></select>
              <button type="button" id="new-document" title="Neues Dokument">+</button>
              <button type="button" id="delete-document" title="Dokument löschen">🗑</button>
            </div>
            <div class="document-bar">
              <button type="button" id="export-yaml">YAML exportieren</button>
              <button type="button" id="import-yaml">YAML importieren</button>
              <input type="file" id="import-yaml-input" accept=".yaml,.yml" hidden />
            </div>
          </header>

          <section class="fields">
            <div class="field-row">
              <label>Nr.<input type="text" data-doc="number" /></label>
              <label>Datum<input type="date" data-doc="date" /></label>
            </div>
            <div class="field-row">
              <label>Gültig bis (Offerte)<input type="date" data-doc="validUntil" /></label>
              <label>Zahlbar bis (Rechnung)<input type="date" data-doc="dueDate" /></label>
            </div>

            <h2>Kunde</h2>
            <label>Name<input type="text" data-doc="clientName" /></label>
            <label>Strasse / Nr.<input type="text" data-doc="clientAddress" /></label>
            <div class="field-row zip-city">
              <label>PLZ<input type="text" data-doc="clientZip" /></label>
              <label>Ort<input type="text" data-doc="clientCity" /></label>
            </div>

            <h2>Text</h2>
            <label>Einleitung<textarea rows="3" data-doc="introText"></textarea></label>
            <label>Schlusstext<textarea rows="2" data-doc="closingText"></textarea></label>

            <h2>Positionen</h2>
            <table class="items-editor">
              <thead>
                <tr><th>Beschreibung</th><th>Menge</th><th>Einheit</th><th>Ansatz</th><th></th></tr>
              </thead>
              <tbody id="items-body"></tbody>
            </table>
            <button type="button" id="add-item">+ Position</button>

            <div class="field-row vat-row">
              <label class="checkbox">
                <input type="checkbox" data-doc="vatEnabled" /> MWST ausweisen
              </label>
              <label>Satz %<input type="number" step="0.1" min="0" data-doc="vatRate" /></label>
              <label>Währung
                <select data-doc="currency">
                  <option value="CHF">CHF</option>
                  <option value="EUR">EUR</option>
                </select>
              </label>
            </div>

            <details class="settings">
              <summary>Absender & IBAN</summary>
              <label>Name<input type="text" data-setting="name" /></label>
              <label>Strasse / Nr.<input type="text" data-setting="address" /></label>
              <div class="field-row zip-city">
                <label>PLZ<input type="text" data-setting="zip" /></label>
                <label>Ort<input type="text" data-setting="city" /></label>
              </div>
              <label>IBAN<input type="text" data-setting="iban" /></label>
              <label>E-Mail<input type="text" data-setting="email" /></label>
              <label>Telefon<input type="text" data-setting="phone" /></label>
              <label>MWST-Nr.<input type="text" data-setting="vatNumber" /></label>
            </details>
          </section>
        </div>
      </aside>

      <main class="preview">
        <div class="toolbar">
          <div class="mode-toggle">
            <button type="button" data-mode="offerte">Offerte</button>
            <button type="button" data-mode="rechnung">Rechnung</button>
          </div>
          <div class="print-buttons">
            <button type="button" class="primary" data-print="offerte">PDF Offerte</button>
            <button type="button" class="primary" data-print="rechnung">PDF Rechnung</button>
          </div>
        </div>
        <div class="sheet-scroll">
          <div id="sheet" class="sheet rechnung"></div>
        </div>
      </main>
    </div>
    <script>
      import "../lib/app";
    </script>
  </body>
</html>
